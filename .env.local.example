# Supabase — find these in your Supabase project dashboard under Settings > API
# For local dev these are printed by `supabase start`
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-anon-key
SUPABASE_SECRET_KEY=your-service-role-key

# Direct database connection — useful for migrations and DB tooling
# For local dev: postgres://postgres:postgres@127.0.0.1:54322/postgres
DATABASE_URL=postgresql://postgres:postgres@your-project-ref.supabase.co:5432/postgres
DIRECT_URL=postgresql://postgres:postgres@your-project-ref.supabase.co:5432/postgres

# Supabase Storage (S3-compatible) — for local dev these are printed by `supabase start`
# For production, find these in your Supabase dashboard under Settings > Storage
SUPABASE_STORAGE_S3_URL=http://127.0.0.1:54321/storage/v1/s3
SUPABASE_STORAGE_S3_ACCESS_KEY=your-storage-access-key
SUPABASE_STORAGE_S3_SECRET_KEY=your-storage-secret-key
SUPABASE_STORAGE_S3_REGION=local

# Feature flags — set to "true" to enable (defaults to off)
# Enable only after running the DB migration and configuring Google OAuth
NEXT_PUBLIC_GOOGLE_AUTH_ENABLED=false

# Google OAuth credentials — for local dev, the Supabase CLI reads these from this file
# In production, enter them in the Supabase dashboard (Authentication > Providers > Google) instead
# Obtain from https://console.cloud.google.com under APIs & Services > Credentials
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=your-google-client-id
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=your-google-client-secret

# Steps to enable Google OAuth:
# 1. Create OAuth 2.0 credentials at https://console.cloud.google.com
#    - Authorized JavaScript origins: http://localhost:3000, https://your-domain.com
#    - Authorized redirect URIs: http://127.0.0.1:54321/auth/v1/callback (local),
#      https://your-project-ref.supabase.co/auth/v1/callback (production),
#      https://your-domain.com/auth/callback (production)
# 2. For local dev: add client ID and secret above, then restart Supabase (supabase stop && supabase start)
# 3. For production: enter credentials in Supabase dashboard > Authentication > Providers > Google
# 4. Run the migration: supabase db push  (or paste the SQL from supabase/migrations/ into the dashboard SQL editor)
