# Supabase — find these in your Supabase project dashboard under Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Steps to enable Google OAuth:
# 1. Go to Supabase Dashboard > Authentication > Providers > Google
# 2. Enable Google and enter your Client ID and Client Secret
#    (create these at https://console.cloud.google.com under APIs & Services > Credentials)
# 3. Add your site URL + /auth/callback as an authorised redirect URI in Google Cloud Console
#    e.g. http://localhost:3000/auth/callback (dev) and https://your-domain.com/auth/callback (prod)
# 4. Run the migration:  supabase db push  (or paste the SQL from supabase/migrations/ into the dashboard SQL editor)
